@PACKAGE_INIT@

# threadmaxx — CMake package config.
#
# Generated by `configure_package_config_file` (see top-level
# CMakeLists.txt). Imported via:
#
#   find_package(threadmaxx 1.2 CONFIG REQUIRED)
#   target_link_libraries(my_target PRIVATE threadmaxx::threadmaxx)
#
# The core library has one direct external dependency — the C++
# `Threads` library — and we re-find it here so downstream consumers
# don't have to. The audio sibling's optional ALSA + PulseAudio
# backends are PRIVATE-linked but still need to resolve symbols at
# the consumer's link step, so we re-find them here when they were
# present at install time.

include(CMakeFindDependencyMacro)
find_dependency(Threads)

include("${CMAKE_CURRENT_LIST_DIR}/threadmaxxTargets.cmake")

# The audio sibling's optional backends are PRIVATE-linked via
# $<LINK_ONLY:…> in the exported target, so the symbols need to
# resolve at consumer link time even though no public header
# references them. Found QUIET so consumers without the dev packages
# can still use the rest of the suite — the link step will surface a
# clear error for any consumer that actually pulls audio in.
if (TARGET threadmaxx::threadmaxx_audio)
    find_package(ALSA QUIET)
    find_package(PkgConfig QUIET)
    if (PkgConfig_FOUND)
        pkg_check_modules(PULSESIMPLE QUIET libpulse-simple)
        if (PULSESIMPLE_FOUND)
            # The exported target references the unqualified `pulse-simple`
            # and `pulse` library names; surface them as plain link items
            # via add_library(... IMPORTED) so target resolution sees them.
            if (NOT TARGET pulse-simple)
                add_library(pulse-simple SHARED IMPORTED)
                find_library(_TMX_PULSESIMPLE_LIB NAMES pulse-simple)
                if (_TMX_PULSESIMPLE_LIB)
                    set_target_properties(pulse-simple PROPERTIES
                        IMPORTED_LOCATION "${_TMX_PULSESIMPLE_LIB}")
                endif()
                unset(_TMX_PULSESIMPLE_LIB)
            endif()
            if (NOT TARGET pulse)
                add_library(pulse SHARED IMPORTED)
                find_library(_TMX_PULSE_LIB NAMES pulse)
                if (_TMX_PULSE_LIB)
                    set_target_properties(pulse PROPERTIES
                        IMPORTED_LOCATION "${_TMX_PULSE_LIB}")
                endif()
                unset(_TMX_PULSE_LIB)
            endif()
        endif()
    endif()
endif()

# Each sibling library is exported under its long
# `threadmaxx::threadmaxx_<x>` name; re-add the short
# `threadmaxx::<x>` alias so downstream code can use the same name
# as in-tree builds. Each alias is only added when the matching
# target was actually installed (i.e. THREADMAXX_BUILD_<X> was ON at
# install time).
foreach(_tmx_sibling
        simd animation assets audio editor input migration
        navmesh network physics reflect studio ui)
    if (TARGET threadmaxx::threadmaxx_${_tmx_sibling}
        AND NOT TARGET threadmaxx::${_tmx_sibling})
        add_library(threadmaxx::${_tmx_sibling}
                    ALIAS threadmaxx::threadmaxx_${_tmx_sibling})
    endif()
endforeach()
unset(_tmx_sibling)

check_required_components(threadmaxx)
