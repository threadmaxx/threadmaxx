@PACKAGE_INIT@

# threadmaxx — CMake package config.
#
# Generated by `configure_package_config_file` (see top-level
# CMakeLists.txt). Imported via:
#
#   find_package(threadmaxx 1.0 CONFIG REQUIRED)
#   target_link_libraries(my_target PRIVATE threadmaxx::threadmaxx)
#
# The library has one direct external dependency — the C++
# `Threads` library — and we re-find it here so downstream consumers
# don't have to.

include(CMakeFindDependencyMacro)
find_dependency(Threads)

include("${CMAKE_CURRENT_LIST_DIR}/threadmaxxTargets.cmake")

# Sibling SIMD library — only present when THREADMAXX_BUILD_SIMD was
# ON at install time. The export uses the literal target name
# (`threadmaxx::threadmaxx_simd`); add the short `threadmaxx::simd`
# alias so downstream code can use the same name as in-tree builds.
if (TARGET threadmaxx::threadmaxx_simd AND NOT TARGET threadmaxx::simd)
    add_library(threadmaxx::simd ALIAS threadmaxx::threadmaxx_simd)
endif()

check_required_components(threadmaxx)
